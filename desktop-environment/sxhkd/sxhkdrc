#########################
## bspwm/sxhkd hotkeys ##
#########################

# quit bspwm
super + alt + q
	bspc quit

# re-detect topology and apply best-matching monitor profile
super + alt + r
	~/.config/bspwm/scripts/apply-auto.sh

# emergency: in-place bspwm restart (rarely needed; topology changes go through super+alt+r)
super + alt + ctrl + r
	bspc wm -r

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

#####################
## Node Management ##
#####################

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags
# super + shift + {m,x,y,z}
# 	bspc node -g {marked,locked,sticky,private}
super + shift + y
	bspc node -g sticky

